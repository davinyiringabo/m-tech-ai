# Root environment for docker-compose. Copy to .env and adjust as needed:
#   cp .env.example .env
# Compose auto-loads this file. All values have sane defaults in
# docker-compose.yml, so .env is optional.

# --- Postgres ---
POSTGRES_USER=minetech
POSTGRES_PASSWORD=minetech
POSTGRES_DB=minetech
POSTGRES_PORT=5432

# --- Backend ---
BACKEND_PORT=4000
CORS_ORIGIN=http://localhost:3000
# Ollama runs on the host, not in Docker. Containers reach it via host.docker.internal.
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
RAG_TOP_K=4
RAG_MIN_SIMILARITY=0.35

# --- Frontend ---
FRONTEND_PORT=3000
# Inlined into the browser bundle at build time; the browser runs on the host.
NEXT_PUBLIC_API_URL=http://localhost:4000/api
