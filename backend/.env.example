# Backend
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://minetech:minetech@localhost:5432/minetech

# Ollama (self-hosted LLM)
OLLAMA_HOST=http://localhost:11434
# Primary generation model. Swap to qwen2.5:3b to A/B test structured output.
OLLAMA_CHAT_MODEL=llama3.2
# Embedding model for RAG. Pull with: ollama pull nomic-embed-text
OLLAMA_EMBED_MODEL=nomic-embed-text

# RAG tuning
RAG_TOP_K=4
# Minimum cosine similarity for a chunk to count as relevant.
# Below this for the best match => "not in the knowledge base".
RAG_MIN_SIMILARITY=0.35
