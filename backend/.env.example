# Backend
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://useername:password@localhost:5432/db

# Ollama (self-hosted LLM, can be local or remote)
OLLAMA_HOST=http://localhost:11434
# Primary generation model. 
OLLAMA_CHAT_MODEL=llama3.2
# Embedding model for RAG.
OLLAMA_EMBED_MODEL=nomic-embed-text

# RAG tuning
RAG_TOP_K=4
# Minimum cosine similarity for a chunk to count as relevant. Below this for the best match => "not in the knowledge base".
RAG_MIN_SIMILARITY=0.35
